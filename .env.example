BACKEND_PORT=8000
FRONTEND_PORT=5173

# Carpeta con los 4 Excel de origen, montada de solo lectura dentro del contenedor backend.
DATA_DIR=./data_mock

# Límite de memoria del contenedor backend (docker-compose.yml deploy.resources.limits.memory).
BACKEND_MEM_LIMIT=512M

# Cantidad de workers de Gunicorn (backend/Dockerfile, flag -w). Conservador a propósito: un
# worker por defecto para no superar BACKEND_MEM_LIMIT (cada worker Uvicorn puede tener su
# propio DataFrame de Pandas en memoria durante una request).
WEB_CONCURRENCY=1
